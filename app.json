{
  "expo": {
    "name": "AIQ-FE",
    "slug": "aiq-fe",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "aiq",
    "userInterfaceStyle": "automatic",
    "plugins": ["expo-router", "expo-secure-store"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aiq.app"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.aiq.app"
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
