{
  "expo": {
    "name": "AIQ-FE",
    "slug": "AIQ-FE",
    "version": "1.0.0",
    "orientation": "portrait",

    /* 다크/라이트 자동 */
    "userInterfaceStyle": "automatic",

    /* Expo Router 사용 */
    "plugins": ["expo-router"],

    /* iOS 기본 설정 */
    "ios": {
      "supportsTablet": true
    },

    /* Android 기본 설정 */
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },

    /* 실험 기능 */
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
